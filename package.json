{
	"name": "besidka",
	"type": "module",
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"preinstall": "node scripts/verify-node-types.mjs",
		"build": "ROLLDOWN_OPTIONS_VALIDATION=loose nuxt build",
		"dev": "nuxt dev --dotenv .dev.vars",
		"preview": "pnpm run build && wrangler dev --port 3000",
		"remote:preview": "pnpm run build && wrangler dev --port 3000 --remote",
		"prod:preview": "pnpm run build && wrangler dev --port 3000 --env production --remote",
		"deploy": "pnpm run build && wrangler deploy",
		"deploy:prod": "pnpm run build && wrangler deploy --env production",
		"generate": "nuxt generate",
		"dev:prepare": "nuxt prepare",
		"typecheck": "nuxt typecheck",
		"analyze": "ROLLDOWN_OPTIONS_VALIDATION=loose nuxt analyze",
		"cf-typegen": "wrangler types",
		"lint": "eslint",
		"format": "eslint --fix",
		"test": "vitest",
		"test:unit": "vitest run tests/unit",
		"test:unit:changed": "vitest run tests/unit --changed",
		"test:unit:related": "vitest run tests/unit --related",
		"test:unit:watch": "vitest tests/unit",
		"test:integration": "vitest run tests/integration --passWithNoTests",
		"test:integration:watch": "vitest tests/integration",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui --headed --debug",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:chromium": "playwright test --project=chromium",
		"test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
		"test:affected": "node scripts/test-affected.mjs",
		"test:affected:unit": "node scripts/test-affected.mjs --type=unit",
		"test:affected:integration": "node scripts/test-affected.mjs --type=integration",
		"test:affected:e2e": "node scripts/test-affected.mjs --type=e2e",
		"test:affected:fast": "node scripts/test-affected.mjs --type=unit && node scripts/test-affected.mjs --type=integration",
		"coverage": "vitest run --coverage --passWithNoTests",
		"coverage:ui": "vitest --coverage --ui",
		"db:generate": "drizzle-kit generate",
		"db:reset": "rm -rf .wrangler/state/v3/d1 && drizzle-kit generate && pnpm exec wrangler d1 migrations apply DB",
		"db:migrate": "pnpm exec wrangler d1 migrations apply DB",
		"db:migrate:preview": "pnpm exec wrangler d1 migrations apply DB --remote",
		"db:migrate:prod": "pnpm exec wrangler d1 migrations apply DB --env production --remote",
		"db:studio": "drizzle-kit studio",
		"db:consents:generate": "drizzle-kit generate --config=drizzle-consent.config.ts",
		"db:consents:migrate": "pnpm exec wrangler d1 migrations apply CONSENT_DB",
		"db:consents:migrate:preview": "pnpm exec wrangler d1 migrations apply CONSENT_DB --remote",
		"db:consents:migrate:prod": "pnpm exec wrangler d1 migrations apply CONSENT_DB --env production --remote",
		"prepare": "husky",
		"postinstall": "node scripts/setup-ai-agents.mjs && pnpm --filter @besidka/nuxt-cookie-consent dev:prepare && nuxt prepare",
		"test:cookie-consent": "pnpm --filter @besidka/nuxt-cookie-consent test:run",
		"landing:video": "node scripts/landing-demo-video.mjs",
		"cms:files:upload": "node scripts/cms-bucket-manager.mjs upload",
		"cms:files:download": "node scripts/cms-bucket-manager.mjs download"
	},
	"dependencies": {
		"@ai-sdk/google": "^4.0.5",
		"@ai-sdk/openai": "^4.0.5",
		"@ai-sdk/provider": "^4.0.1",
		"@ai-sdk/vue": "^4.0.11",
		"@besidka/nuxt-cookie-consent": "workspace:*",
		"@iconify-json/lucide": "^1.2.115",
		"@nuxt/content": "^3.14.0",
		"@nuxt/eslint": "^1.16.0",
		"@nuxt/fonts": "^0.14.0",
		"@nuxt/icon": "^2.2.5",
		"@nuxt/image": "^2.0.0",
		"@nuxtjs/color-mode": "^4.0.1",
		"@nuxtjs/device": "^4.0.0",
		"@nuxtjs/i18n": "^10.4.0",
		"@nuxtjs/mdc": "^0.22.0",
		"@nuxtjs/robots": "^6.1.2",
		"@nuxtjs/sitemap": "^8.2.2",
		"@tailwindcss/vite": "^4.3.2",
		"@vite-pwa/nuxt": "^1.1.1",
		"@vueuse/core": "^14.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"ai": "^7.0.11",
		"better-auth": "^1.6.23",
		"crypto-shield": "^1.6.2",
		"daisyui": "^5.6.7",
		"defu": "^6.1.7",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "0.45.2",
		"drizzle-query-logger": "^1.1.2",
		"eslint": "^10.6.0",
		"evlog": "2.19.2",
		"hashids": "^2.3.0",
		"nuxt": "^4.4.8",
		"nuxt-studio": "^1.7.0",
		"nuxt-svgo": "^5.3.0",
		"plyr": "^3.8.4",
		"remark-breaks": "^4.0.0",
		"resend": "6.16.0",
		"sanitize-html": "^2.17.5",
		"shiki": "^4.3.0",
		"shiki-stream": "^0.1.5",
		"tailwindcss": "^4.3.2",
		"ulid": "^3.0.2",
		"vue": "^3.5.39",
		"vue-router": "^5.1.0",
		"web-haptics": "0.0.6",
		"web-push": "^3.6.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260525.1",
		"@commitlint/cli": "^21.0.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@commitlint/format": "^21.0.0",
		"@commitlint/types": "^21.0.0",
		"@nuxt/kit": "^4.4.8",
		"@nuxt/test-utils": "^4.0.3",
		"@playwright/test": "^1.60.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "24.12.4",
		"@types/sanitize-html": "^2.16.1",
		"@types/web-push": "^3.6.4",
		"@vitest/coverage-v8": "^4.1.7",
		"@vitest/ui": "^4.1.7",
		"@vue/test-utils": "^2.4.10",
		"better-sqlite3": "^12.10.0",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"mediabunny": "^1.46.0",
		"msw": "^2.14.6",
		"playwright-core": "^1.60.0",
		"typescript": "^6.0.3",
		"vite-plugin-eslint2": "^5.1.0",
		"vitest": "^4.1.7",
		"vitest-environment-nuxt": "^2.0.0",
		"vue-tsc": "^3.3.2",
		"whatwg-fetch": "^3.6.20",
		"wrangler": "^4.94.0"
	},
	"peerDependencies": {
		"@react-email/render": "^2.0.4"
	},
	"peerDependenciesMeta": {
		"@react-email/render": {
			"optional": true
		}
	},
	"overrides": {
		"vite": "npm:rolldown-vite@latest"
	},
	"lint-staged": {
		"*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,vue}": [
			"eslint --fix"
		]
	}
}