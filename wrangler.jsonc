{
	"name": "besidka-preview",
	"compatibility_date": "2026-01-28",
	"workers_dev": true,
	"preview_urls": true,
	"main": ".output/server/index.mjs",
	"assets": {
		"binding": "ASSETS",
		"directory": ".output/public"
	},
	"compatibility_flags": [
		"nodejs_compat",
		"no_nodejs_compat_v2",
		"nodejs_als"
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"traces": {
			"enabled": true,
			"head_sampling_rate": 1
		}
	},
	"placement": {
		"mode": "smart"
	},
	"vars": {
		"NUXT_PUBLIC_BASE_URL": "https://besidka-preview.chernenko.workers.dev",
		"NUXT_RESEND_SENDER_NOREPLY": "noreply@besidka.com",
		"NUXT_RESEND_SENDER_PERSONALIZED": "serhii@besidka.com",
		"NUXT_VAPID_SUBJECT": "abuse@besidka.com",
		"NUXT_PUBLIC_VAPID_PUBLIC_KEY": "BJECS1JELjYP0aXYJdlCqKA1DzKRfG70EEYo1FB3v6M8-oRA25ufhWgRZ32ZKanL0CX585c3mLCQQnnIeeBvAc8",
		"NUXT_FILES_RETENTION_CLEANUP_ENABLED": true,
		"NUXT_FILES_RETENTION_CLEANUP_BATCH_SIZE": 100,
		"NUXT_FILES_RETENTION_CLEANUP_MAX_RUNTIME_MS": 20000
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "besidka-preview",
			"database_id": "d30ca34f-9b29-4846-a77b-fcbda41cb598",
			"migrations_dir": ".drizzle/migrations"
		},
		{
			"binding": "CONSENT_DB",
			"database_name": "besidka-consent-preview",
			"database_id": "d110f034-1e7a-4512-b4c0-bc1e881b6d02",
			"migrations_dir": ".drizzle/migrations-consent"
		},
		// Nuxt Content v3 uses a dedicated D1 database, separate from the
		// main app DB, to avoid Drizzle migration blast-radius on chat/user
		// data. See README.md § "Content (Nuxt Content + Studio)" for the
		// wrangler d1 create commands to get the real database_id.
		{
			"binding": "CONTENT_DB",
			"database_name": "besidka-content-preview",
			"database_id": "32796d2a-29cc-45f7-99c9-37c6f171f754"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "6ee10a2a05034ba092a9fb815f633e06"
		}
	],
	"r2_buckets": [
		{
			"bucket_name": "besidka-preview",
			"binding": "DATA_BUCKET"
		},
		{
			"bucket_name": "besidka-cms-preview",
			"binding": "CMS_BUCKET"
		}
	],
	"analytics_engine_datasets": [
		{
			"binding": "ANALYTICS",
			"dataset": "besidka_cms_events_preview"
		}
	],
	"images": {
    "binding": "IMAGES"
  },
	"triggers": {
		"crons": [
			"0 * * * *"
		]
	},
	"env": {
		"production": {
			"name": "besidka",
			"workers_dev": false,
			"preview_urls": false,
			"main": ".output/server/index.mjs",
			"assets": {
				"binding": "ASSETS",
				"directory": ".output/public"
			},
			"routes": [
				{
					"custom_domain": true,
					"pattern": "besidka.com"
				},
				{
					"pattern": "www.besidka.com/*",
					"zone_name": "besidka.com"
				}
			],
			"triggers": {
				"crons": [
					"0 * * * *"
				]
			},
			"observability": {
				"enabled": true,
				"head_sampling_rate": 1,
				"traces": {
					"enabled": true,
					"head_sampling_rate": 0.1
				}
			},
			"vars": {
				"NUXT_PUBLIC_BASE_URL": "https://www.besidka.com",
				"NUXT_RESEND_SENDER_NOREPLY": "noreply@besidka.com",
				"NUXT_RESEND_SENDER_PERSONALIZED": "serhii@besidka.com",
				"NUXT_VAPID_SUBJECT": "abuse@besidka.com",
				"NUXT_PUBLIC_VAPID_PUBLIC_KEY": "BJECS1JELjYP0aXYJdlCqKA1DzKRfG70EEYo1FB3v6M8-oRA25ufhWgRZ32ZKanL0CX585c3mLCQQnnIeeBvAc8",
				"NUXT_FILES_RETENTION_CLEANUP_ENABLED": true,
				"NUXT_FILES_RETENTION_CLEANUP_BATCH_SIZE": 100,
				"NUXT_FILES_RETENTION_CLEANUP_MAX_RUNTIME_MS": 20000,
				"NUXT_AXIOM_DATASET": "besidka-prod",
				"NUXT_AXIOM_AUDIT_DATASET": "besidka-audit-prod",
				"NUXT_AXIOM_CONSENT_DATASET": "besidka-consent-prod"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "besidka",
					"database_id": "4d03fd8e-027e-4485-bd11-f387b1677e88",
					"migrations_dir": ".drizzle/migrations"
				},
				{
					"binding": "CONSENT_DB",
					"database_name": "besidka-consent",
					"database_id": "d79f8088-c9ce-4d55-a07c-e3bd564354fb",
					"migrations_dir": ".drizzle/migrations-consent"
				},
				// Nuxt Content v3 dedicated D1 (production). See README.md
				// § "Content (Nuxt Content + Studio)" for setup.
				{
					"binding": "CONTENT_DB",
					"database_name": "besidka-content",
					"database_id": "0d1eab21-938c-4c7b-8aa4-bbfabd9a4a17"
				}
			],
			"kv_namespaces": [
				{
					"binding": "KV",
					"id": "eb7450a0ca6f4e6ba0b7ab7fd92f3e6a"
				}
			],
			"r2_buckets": [
				{
					"bucket_name": "besidka",
					"binding": "DATA_BUCKET"
				},
				{
					"bucket_name": "besidka-cms",
					"binding": "CMS_BUCKET"
				}
			],
			"analytics_engine_datasets": [
				{
					"binding": "ANALYTICS",
					"dataset": "besidka_cms_events"
				}
			],
			"images": {
				"binding": "IMAGES"
			}
		}
	}
}
