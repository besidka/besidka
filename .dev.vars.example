# Drizzle
NUXT_ENCRYPTION_HASHIDS=secret
NUXT_ENCRYPTION_KEY=secret

# Cloudflare Email Sending (Workers binding — no API key needed).
# Domain besidka.com must be onboarded to Email Sending.
# Senders are set via wrangler.jsonc vars; only the noop flag lives here.
# Set true in CI E2E to skip real email sending.
NUXT_EMAIL_NOOP_ENABLED=false

# Better Auth
NUXT_BETTER_AUTH_SECRET=secret

# Google OAuth API
# https://console.cloud.google.com/apis/dashboard
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=

# GitHub OAuth API
# https://github.com/settings/applications
NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=

# Files retention cleanup
NUXT_FILES_RETENTION_CLEANUP_ENABLED=false
NUXT_FILES_RETENTION_CLEANUP_BATCH_SIZE=100
NUXT_FILES_RETENTION_CLEANUP_MAX_RUNTIME_MS=20000
NUXT_FILES_MAINTENANCE_TOKEN=

# Deep research job sweep (cron finalizes jobs a client isn't actively polling)
NUXT_RESEARCH_SWEEP_ENABLED=false
NUXT_RESEARCH_SWEEP_BATCH_SIZE=20
NUXT_RESEARCH_SWEEP_MAX_RUNTIME_MS=20000

# Axiom observability (production only)
NUXT_AXIOM_DATASET=
NUXT_AXIOM_TOKEN=
NUXT_AXIOM_AUDIT_DATASET=
NUXT_AXIOM_AUDIT_TOKEN=
NUXT_AXIOM_CONSENT_DATASET=
NUXT_AXIOM_CONSENT_TOKEN=

# Nuxt Studio — credentials for the PRODUCTION self-hosted editor (optional).
# NOT needed for local development: with `pnpm run dev` the editor is the
# "Edit this page" floating button (bottom-left) that writes straight to the
# local files — no auth, no env vars. Publishing (Git commits) is disabled in
# dev. These credentials only power the deployed editor at /_studio, where
# editors sign in with GitHub and changes are committed to the repo.
# Setup: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   Homepage URL:               https://www.besidka.com
#   Authorization callback URL: https://www.besidka.com/_studio
#   (use the canonical www host — prod redirects besidka.com → www.besidka.com,
#    and the OAuth callback must match the final host exactly)
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=

# Web Push — "your response is ready" notifications.
# Generate a keypair once with: node scripts/generate-vapid-keys.mjs
# The matching public key goes into wrangler.jsonc
# (NUXT_PUBLIC_VAPID_PUBLIC_KEY) and MUST come from the same run — the
# Worker validates the pair on every send and rejects mismatches. Requests
# are built by server/utils/push-protocol.ts (in-house WebCrypto RFC
# 8291/8292; no Web Push library survives workerd against Apple).
NUXT_VAPID_PRIVATE_KEY=
